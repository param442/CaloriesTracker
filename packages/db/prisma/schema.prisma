model Account {
  id                String   @id @default(cuid())
  userAuthId        String   @unique
  provider          String
  providerAccountId String
  refresh_token     String?  
  access_token      String?  
  expires_at        Int?     
  token_type        String?  
  scope             String?  
  id_token          String?  
  session_state     String?  

  userAuth          UserAuth @relation(fields: [userAuthId], references: [id])
}


model session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userAuthId   String
  expires      DateTime

  userAuth     UserAuth @relation(fields: [userAuthId], references: [id])
}



model UserAuth {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  account       Account[]
  session       session[]
  userData      UserData?
}

model UserData {
  id                 String   @id @default(cuid())
  userId             String   @unique
  firstName          String
  lastName           String
  dateOfBirth       DateTime
  gender             String
  height             Float
  activityLevel      String
  goal               String
  currentWeight      Float
  targetWeight       Float
  calorieIntakeGoal Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userAuth           UserAuth @relation(fields: [userId], references: [id])
}